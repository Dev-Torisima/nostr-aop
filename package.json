{
  "name": "nostr-aop",
  "version": "0.1.1",
  "description": "Nostr-aop is applicaion Object Protocol (AOP) SDK for Nostr. It allow to build server-less apps using data transmission.",
  "scripts": {
    "build": "npm run clear && npm run build:node && npm run build:browser",
    "clear": "rimraf dist",
    "build:node": "tsc -p tsconfig.json",
    "build:browser": "tsc -p tsconfig.browser.json",
    "demo:browser": "esbuild src/browser.ts --bundle --outfile=dist/nostr-aop.browser.js --format=esm --platform=browser"
  },
  "keywords": [
    "nostr",
    "aop",
    "protocol",
    "typescript"
  ],
  "author": "torisima",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dev-Torisima/nostr-aop"
  },
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "nostr-tools": "^2.23.12"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    }
  }
}
